  "typography": {
    "fontDisplay": "'Bricolage Grotesque', Georgia, serif",
    "fontBody": "'Karla', system-ui, sans-serif"
  },
  "elevation": {
    "shadow-xs": "0 1px 2px rgba(0, 0, 0, 0.25)",
    "shadow-sm": "0 1px 4px rgba(0, 0, 0, 0.3), 0 1px 2px rgba(0, 0, 0, 0.2)",
    "shadow-md": "0 4px 16px rgba(0, 0, 0, 0.35), 0 1px 4px rgba(0, 0, 0, 0.25)",
