{
  "id": "midnight",
  "name": "Midnight",
  "description": "Deep navy and muted golds — elegant dark mode",
  "author": "Toto",
  "version": "2.0.0",
  "colorScheme": "dark",
  "palette": {
    "bg": "#0f1219",
    "surface": "#1a1f2e",
    "ink": "#d8dce6",
    "ink-secondary": "#8d94a6",
    "ink-muted": "#5a6178",
    "ink-light": "#3d4458",
    "accent": "#c4a05a",
    "accent-hover": "#d4b46e",
    "accent-subtle": "rgba(196, 160, 90, 0.1)",
    "green": "#5a9e7a",
    "green-hover": "#6eb88e",
    "green-subtle": "rgba(90, 158, 122, 0.1)",
    "red": "#c45a5a",
    "red-hover": "#d47070",
    "red-subtle": "rgba(196, 90, 90, 0.08)",
    "border": "rgba(255, 255, 255, 0.08)",
    "border-light": "rgba(255, 255, 255, 0.04)",
    "bg-tint-1": "rgba(196, 160, 90, 0.03)",
    "bg-tint-2": "rgba(90, 158, 122, 0.02)"
