  },
  "animations": {
    "colors": {
      "flash": "#0f1219",
      "glow": "rgba(196, 160, 90, 0.25)",
      "particles": {
        "impact": [[196, 160, 90], [180, 140, 70]],
        "smoke": [[90, 95, 110]],
        "fire": [[196, 160, 90], [220, 180, 100]],
        "debris": [[140, 130, 120]],
        "confetti": [[196, 160, 90], [90, 158, 122], [180, 140, 200], [200, 200, 220]],
        "hearts": [[196, 160, 90]],
        "sparkle": [[220, 200, 150], [196, 160, 90]]
      }
    },
    "chars": {
      "particles": ["#", "*", "+", "=", "~", "^"],
      "smoke": ["\u2591", "\u2592", "~", "\u2248"],
      "confetti": ["*", "+", "\u2726", "\u2605"],
      "fire": ["*", "\u2726", "\u2668", "#"],
      "debris": ["\u2591", "\u2592", "\u2593", "#", "^"],
      "shatter": ["\u2571", "\u2572", "\u2502", "\u2500", "\u2573"],
      "blast": ["\u2588", "\u2593", "\u2592", "#", "@"],
      "hearts": ["\u2665"],
      "sparkle": ["\u2726", "\u2727", "*"]
