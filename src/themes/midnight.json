    "effects": {
      "flashOpacity": 0.5,
      "glowIntensity": 0.3,
      "particleTrails": false,
      "impactRipple": true,
      "screenTint": "rgba(196, 160, 90, 0.02)",
      "badgeAnimation": "pop"
