{
  "id": "mono",
  "name": "Monochrome",
  "description": "Clean grayscale — understated elegance",
  "author": "Toto",
  "version": "2.0.0",
  "colorScheme": "light",
  "palette": {
    "bg": "#f2f2f2",
    "surface": "#ffffff",
    "ink": "#1a1a1a",
    "ink-secondary": "#555555",
    "ink-muted": "#888888",
    "ink-light": "#aaaaaa",
    "accent": "#333333",
    "accent-hover": "#555555",
    "accent-subtle": "rgba(0, 0, 0, 0.05)",
    "green": "#666666",
    "green-hover": "#777777",
    "green-subtle": "rgba(0, 0, 0, 0.04)",
    "red": "#555555",
    "red-hover": "#666666",
    "red-subtle": "rgba(0, 0, 0, 0.04)",
    "border": "#d4d4d4",
    "border-light": "#e8e8e8",
    "bg-tint-1": "transparent",
    "bg-tint-2": "transparent"
  },
  "typography": {
    "fontDisplay": "'Bricolage Grotesque', Georgia, serif",
    "fontBody": "'Karla', system-ui, sans-serif"
  },
  "elevation": {
    "shadow-xs": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "shadow-sm": "0 1px 4px rgba(0, 0, 0, 0.08), 0 1px 2px rgba(0, 0, 0, 0.04)",
    "shadow-md": "0 4px 16px rgba(0, 0, 0, 0.1), 0 1px 4px rgba(0, 0, 0, 0.06)",
    "shadow-hover": "0 8px 24px rgba(0, 0, 0, 0.12), 0 2px 6px rgba(0, 0, 0, 0.06)"
  },
  "animations": {
    "colors": {
      "flash": "#f2f2f2",
      "glow": "rgba(0, 0, 0, 0.15)",
      "particles": {
        "impact": [[80, 80, 80], [120, 120, 120]],
        "smoke": [[100, 100, 100]],
        "fire": [[60, 60, 60], [100, 100, 100]],
        "debris": [[160, 160, 160]],
        "confetti": [[50, 50, 50], [120, 120, 120], [180, 180, 180]],
        "hearts": [[80, 80, 80]],
        "sparkle": [[60, 60, 60], [140, 140, 140]]
      }
    },
    "chars": {
      "particles": ["#", "*", "+", "=", "~", "^"],
      "smoke": ["\u2591", "\u2592", "~", "\u2248"],
      "confetti": ["*", "+", "\u2726", "\u2605"],
      "fire": ["*", "\u2726", "#", "+"],
      "debris": ["\u2591", "\u2592", "\u2593", "#", "^"],
      "shatter": ["\u2571", "\u2572", "\u2502", "\u2500", "\u2573"],
      "blast": ["\u2588", "\u2593", "\u2592", "#", "@"],
      "hearts": ["\u2665"],
      "sparkle": ["\u2726", "\u2727", "*"]
    },
    "effects": {
      "flashOpacity": 0.5,
      "glowIntensity": 0.2,
      "particleTrails": false,
      "impactRipple": true,
      "screenTint": "rgba(0, 0, 0, 0.02)",
      "badgeAnimation": "pop"
    }
  }
}
