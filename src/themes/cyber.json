    "ink-muted": "#6a6a8a",
    "ink-light": "#4a4a6a",
    "accent": "#00e5ff",
    "accent-hover": "#33ebff",
    "accent-subtle": "rgba(0, 229, 255, 0.1)",
    "green": "#00ffa3",
    "green-hover": "#33ffb8",
    "green-subtle": "rgba(0, 255, 163, 0.1)",
    "red": "#ff5252",
    "red-hover": "#ff7070",
    "red-subtle": "rgba(255, 82, 82, 0.1)",
    "border": "rgba(255, 255, 255, 0.08)",
    "border-light": "rgba(255, 255, 255, 0.04)",
